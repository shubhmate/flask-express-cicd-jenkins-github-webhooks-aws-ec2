pipeline {
    agent any

    environment {
        APP_DIR  = "express-frontend"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh "cd ${WORKSPACE}/${APP_DIR} && npm install"
            }
        }

        stage('Test') {
            steps {
                sh "cd ${WORKSPACE}/${APP_DIR} && npm test || true"
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    pm2 delete express-frontend || true
                    pm2 start ${WORKSPACE}/${APP_DIR}/app.js --name express-frontend
                    pm2 save
                """
            }
        }
    }

    post {
        success {
            echo 'Express deployment successful!'
        }
        failure {
            echo 'Express deployment failed.'
        }
    }
}
