pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                // sh "cd express-frontend && npm install"
                sh "cd ${WORKSPACE} && npm install"
            }
        }

        stage('Test') {
            steps {
                // sh "cd express-frontend && npm test || true"
                sh "cd ${WORKSPACE} && npm test || true"
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    pm2 delete express-frontend || true
                    pm2 start ${WORKSPACE}/app.js --name express-frontend
                    pm2 save
                """
            }
        }
    }

    post {
        success {
            echo 'Express deployment successful!'
        }
        failure {
            echo 'Express deployment failed.'
        }
    }
}
