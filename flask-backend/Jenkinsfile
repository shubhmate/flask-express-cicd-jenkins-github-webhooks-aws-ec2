pipeline {
    agent any

    environment {
        VENV_DIR = "${WORKSPACE}/flask-backend/venv"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh """
                    cd ${WORKSPACE}/flask-backend
                    python3 -m venv ${VENV_DIR}
                    ${VENV_DIR}/bin/pip install -r requirements.txt
                """
            }
        }

        stage('Test') {
            steps {
                sh "cd ${WORKSPACE}/flask-backend && ${VENV_DIR}/bin/python -m pytest tests/ || true"
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    sudo -u ubuntu pm2 delete flask-backend || true
                    sudo -u ubuntu pm2 start ${VENV_DIR}/bin/python --name flask-backend -- ${WORKSPACE}/flask-backend/app.py
                    sudo -u ubuntu pm2 save
                """
            }
        }
    }

    post {
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed.'
        }
    }
}
