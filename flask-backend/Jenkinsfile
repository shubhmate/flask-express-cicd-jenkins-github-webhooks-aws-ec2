pipeline {
    agent any

    environment {
        VENV_DIR = "${WORKSPACE}/venv"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh """
                    cd flask-backend
                    python3 -m venv ${VENV_DIR}
                    ${VENV_DIR}/bin/pip install -r requirements.txt
                """
            }
        }

        stage('Test') {
            steps {
                sh "cd flask-backend && ${VENV_DIR}/bin/python -m pytest tests/ || true"
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    pm2 delete flask-backend || true
                    pm2 start ${VENV_DIR}/bin/python -- ${WORKSPACE}/app.py --name flask-backend 
                    pm2 save
                """
            }
        }
    }

    post {
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed.'
        }
    }
}
