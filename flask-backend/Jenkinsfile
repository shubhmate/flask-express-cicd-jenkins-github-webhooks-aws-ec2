pipeline {
    agent any

    environment {
        VENV_DIR = "${WORKSPACE}/venv"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh """
                    python3 -m venv ${VENV_DIR}
                    ${VENV_DIR}/bin/pip install -r flask-backend/requirements.txt
                """
            }
        }

        stage('Test') {
            steps {
                sh "${VENV_DIR}/bin/python -m pytest flask-backend/tests/ || true"
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    pm2 delete flask-backend || true
                    pm2 start ${VENV_DIR}/bin/python --name flask-backend -- flask-backend/app.py
                    pm2 save
                """
            }
        }
    }

    post {
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed.'
        }
    }
}
