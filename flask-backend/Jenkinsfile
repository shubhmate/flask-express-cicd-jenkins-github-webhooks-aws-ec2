pipeline {
    agent any

    environment {
        REPO_DIR = "/home/ubuntu/flask-express-cicd-jenkins-github-webhooks-aws-ec2"
        APP_DIR  = "${REPO_DIR}/flask-backend"
        VENV_DIR = "${APP_DIR}/venv"
    }

    stages {
        stage('Checkout') {
            steps {
                dir("${REPO_DIR}") {
                    git branch: 'main', url: 'https://github.com/shubhmate/flask-express-cicd-jenkins-github-webhooks-aws-ec2'
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                sh """
                    cd ${APP_DIR}
                    python3 -m venv ${VENV_DIR}
                    ${VENV_DIR}/bin/pip install -r requirements.txt
                """
            }
        }

        stage('Test') {
            steps {
                sh "${VENV_DIR}/bin/python -m pytest tests/ || true"
            }
        }

        stage('Deploy') {
            steps {
                sh "pm2 restart flask-backend || pm2 start ${VENV_DIR}/bin/python --name flask-backend -- ${APP_DIR}/app.py"
            }
        }
    }

    post {
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed.'
        }
    }
}
