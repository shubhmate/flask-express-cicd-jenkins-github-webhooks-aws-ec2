pipeline {
    agent any

    environment {
        APP_DIR  = "flask-backend"
        VENV_DIR = "${APP_DIR}/venv"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh """
                    cd ${APP_DIR}
                    python3 -m venv ${VENV_DIR}
                    ${VENV_DIR}/bin/pip install -r requirements.txt
                """
            }
        }

        stage('Test') {
            steps {
                sh "cd ${APP_DIR} && ${VENV_DIR}/bin/python -m pytest tests/ || true"
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    pm2 delete flask-backend || true
                    pm2 start ${APP_DIR}/${VENV_DIR}/bin/python --name flask-backend -- ${APP_DIR}/app.py
                    pm2 save
                """
            }
        }
    }

    post {
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed.'
        }
    }
}
